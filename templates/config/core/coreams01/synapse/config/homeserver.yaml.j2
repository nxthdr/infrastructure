server_name: "nxthdr.dev"
public_baseurl: "https://matrix.nxthdr.dev"
pid_file: /data/homeserver.pid

listeners:
  - port: 8008
    tls: false
    type: http
    x_forwarded: true
    bind_addresses: ['::']
    resources:
      - names: [client, federation]
        compress: false
  - port: 9090
    tls: false
    type: metrics
    bind_addresses: ['::']

database:
  name: psycopg2
  args:
    user: "{{ postgresql.username }}"
    password: "{{ postgresql.password }}"
    dbname: synapse
    host: "2a06:de00:50:cafe:10::116"
    port: 5432
    cp_min: 5
    cp_max: 10

log_config: "/data/log.config"

media_store_path: /data/media_store

enable_registration: false
enable_registration_without_verification: false

federation_domain_whitelist: []
allow_public_rooms_without_auth: false
allow_public_rooms_over_federation: false

# Authentication is delegated to Matrix Authentication Service (MSC3861).
# Local passwords, SSO/OIDC providers, and shared-secret registration are all
# disabled — MAS owns authentication entirely. Admin user management happens
# via `mas-cli` instead of the Synapse admin API.
experimental_features:
  msc3861:
    enabled: true
    issuer: https://auth.nxthdr.dev/
    introspection_endpoint: http://[2a06:de00:50:cafe:10::100d]:8080/oauth2/introspect
    client_id: "0000000000000000000SYNAPSE"
    client_auth_method: client_secret_basic
    client_secret: "{{ mas.synapse_client_secret }}"
    # Must match MAS `matrix.secret` — MAS uses this as the bearer token
    # when calling Synapse's admin API; Synapse bypasses introspection for
    # requests whose bearer matches this value.
    admin_token: "{{ mas.synapse_shared_secret }}"
    account_management_url: https://auth.nxthdr.dev/account/

app_service_config_files:
  - /data/hookshot-registration.yml

enable_metrics: true
report_stats: false

suppress_key_server_warning: true
