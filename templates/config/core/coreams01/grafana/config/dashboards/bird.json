            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "count by (instance) (bird_protocol_up{proto=\"BGP\", name!~\"peerlab.*\", instance=~\"$instance\"} == 0)",
          "refId": "A",
          "legendFormat": "{{instance}}"
