      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "bird_protocol_prefix_export_count{proto=\"BGP\", instance=~\"$instance\"}",
          "refId": "A",
          "legendFormat": "{{instance}} / {{name}}"
        }
      ]
    },
    {
