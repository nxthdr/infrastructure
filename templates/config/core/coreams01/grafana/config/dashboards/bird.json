      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "time() - bird_last_reconfig_timestamp_seconds{instance=~\"$instance\"}",
          "refId": "A",
          "legendFormat": "{{instance}}"
        }
      ]
    }
  ],
  "preload": false,
  "refresh": "30s",
  "schemaVersion": 41,
  "tags": [
    "bird",
    "bgp",
    "network"
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "text": "Prometheus",
          "value": "${datasource}"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "refresh": 1,
        "regex": "",
        "label": "Data source"
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource}"
        },
        "definition": "label_values(bird_protocol_up, instance)",
        "query": {
          "query": "label_values(bird_protocol_up, instance)",
          "refId": "StandardVariableQuery"
        },
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 1,
        "label": "Server"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
